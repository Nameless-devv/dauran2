{
  "name": "desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev:web": "vite --port 5174",
    "dev:electron": "wait-on http://localhost:5174 && node run-electron.js",
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:electron\"",
    "build": "vite build && electron-builder",
    "build:vite": "vite build",
    "lint": "eslint src"
  },
  "dependencies": {
    "sql.js": "^1.12.0",
    "axios": "^1.7.9",
    "electron-store": "^10.0.0",
    "lucide-react": "^0.473.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.9",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@tailwindcss/vite": "^4.0.0",
    "concurrently": "^9.1.2",
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "uz.dauran.pos",
    "productName": "Dauran POS",
    "directories": { "output": "release" },
    "files": ["dist/**", "electron/**"],
    "mac": { "category": "public.app-category.business" },
    "win": { "target": "nsis" }
  }
}

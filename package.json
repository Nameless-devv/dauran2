{
  "name": "dauran2",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k --prefix-colors \"cyan,green,magenta\" --names \"backend,web,desktop\" \"pnpm --filter backend dev\" \"pnpm --filter web dev\" \"pnpm --filter desktop dev\"",
    "dev:backend": "pnpm --filter backend dev",
    "dev:web": "pnpm --filter web dev",
    "dev:desktop": "pnpm --filter desktop dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
